# Firebase web app config — copy this file to .env.local and fill in the values
# from Firebase console → Project settings → Your apps → SDK setup (Config).
# These are NOT secrets (they ship to the browser), but keep .env.local untracked.
#
# Until these are set, the app runs in standalone mode (localStorage, no sign-in).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
