# Firebase web app config — copy this file to .env.local and fill in the values
# from Firebase console → Project settings → Your apps → SDK setup (Config).
# These are NOT secrets (they ship to the browser), but keep .env.local untracked.
#
# Until these are set, the app runs in standalone mode (localStorage, no sign-in).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Maps Platform browser key (enables the interactive map picker on the
# Map step). Enable Maps JavaScript API + Maps Static API + Places API, then
# restrict the key by HTTP referrer and to those APIs. Optional — without it the
# Map step falls back to manual image upload.
VITE_GOOGLE_MAPS_API_KEY=
