rules_version = '2';

// Lad Sales Presentation — Firestore security rules.
// Each user owns their proposals under users/{uid}/proposals/*.
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // A user's own proposal drafts (the current draft lives at .../proposals/current).
    match /users/{uid}/proposals/{docId} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // Optional future: a shared org-wide proposals collection.
    // A proposal is readable/writable by its owner; tighten/extend as needed.
    match /proposals/{id} {
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow read, update, delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }
  }
}
