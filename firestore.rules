rules_version = '2';

// Lad Sales Presentation — Firestore security rules (multi-user).
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() { return signedIn() && myRole() == 'admin'; }
    function isCreator() { return signedIn() && (myRole() == 'admin' || myRole() == 'creator'); }
    // Bootstrap admin — keep in sync with src/lib/config.ts ADMIN_EMAILS.
    function isBootstrapAdmin() {
      return signedIn() && request.auth.token.email == 'teamwolf9@gmail.com';
    }
    function tokenEmail() { return request.auth.token.email; }
    function inviteExists() {
      return exists(/databases/$(database)/documents/invites/$(tokenEmail()));
    }
    function invitedRole() {
      return get(/databases/$(database)/documents/invites/$(tokenEmail())).data.role;
    }

    // ---- Invites (admin-managed allowlist) ----
    match /invites/{email} {
      // Admins see all; a user may read only their own invite (for sign-in).
      allow read: if isAdmin() || (signedIn() && email == tokenEmail());
      allow create, update, delete: if isAdmin();
    }

    // ---- User directory ----
    match /users/{uid} {
      allow read: if signedIn();
      // Invite-only self-provision on first sign-in:
      //  - bootstrap admin  → admin, enabled
      //  - pre-invited email → invited role, enabled
      //  - anyone else       → viewer, BLOCKED (disabled) until an admin grants access
      allow create: if signedIn() && request.auth.uid == uid
        && request.resource.data.uid == uid
        && (
          (isBootstrapAdmin()
            && request.resource.data.role == 'admin'
            && request.resource.data.disabled == false)
          || (inviteExists()
            && request.resource.data.role == invitedRole()
            && request.resource.data.disabled == false)
          || (request.resource.data.role == 'viewer'
            && request.resource.data.disabled == true)
        );
      // Admins manage anyone; a user may edit their own profile but not their
      // own role or disabled flag.
      allow update: if isAdmin()
        || (signedIn() && request.auth.uid == uid
            && request.resource.data.role == resource.data.role
            && request.resource.data.disabled == resource.data.disabled);
      allow delete: if isAdmin();
    }

    // ---- Proposals ----
    match /proposals/{id} {
      allow read: if signedIn() && request.auth.uid in resource.data.memberUids;
      // Only admins/creators may create, and the new doc must be owned by them
      // with membership limited to themselves.
      allow create: if isCreator()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.memberUids.hasOnly([request.auth.uid]);
      // Owner: full control. Editor: may change content but not ownership or
      // the sharing membership.
      allow update: if signedIn() && (
          resource.data.ownerUid == request.auth.uid
          || (resource.data.roles[request.auth.uid] == 'editor'
              && request.resource.data.ownerUid == resource.data.ownerUid
              && request.resource.data.roles == resource.data.roles
              && request.resource.data.memberUids == resource.data.memberUids)
        );
      allow delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }
  }
}
